// Tests for N3.5 (first-order error propagation) and N3.6 (closed-form
// propagation shortcuts) -- including a composed check that N3.5's general
// finite-difference path and N3.6's closed-form product shortcut agree on
// the same f(x1,x2) = x1*x2, since sigma_f for a product has a known
// closed form that the general path should reproduce.
// Run with:  vanic test tests/test_error_propagation.vani

use "../src/lib.vani";

fn close(a: f64, b: f64) -> bool {
    return abs(a - b) < 1.0e-3;
}

fn sq(x: f64) -> f64 {
    return x * x;
}

fn prod2(x: ref Vec<f64>, n: i64) -> f64 {
    return x[0] * x[1];
}

fn main() -> i64 {
    // Single-variable: f(x) = x^2, f'(x) = 2x. At x=3, sigma_x=0.1:
    // sigma_f = |2*3| * 0.1 = 0.6.
    let s1: f64 = ep_propagate_1var(sq, 3.0, 0.1, 1.0e-4);
    assert close(s1, 0.6);

    // n-var independent: f(x1,x2) = x1*x2 at (3,4), sigma=(0.1,0.2).
    // df/dx1=x2=4, df/dx2=x1=3 -> sigma_f = sqrt((4*0.1)^2+(3*0.2)^2)
    //                                     = sqrt(0.16+0.36) = sqrt(0.52).
    let x: Vec<f64> = vec(3.0, 4.0);
    let sigmas: Vec<f64> = vec(0.1, 0.2);
    let s2: f64 = ep_propagate_independent(prod2, ref x, ref sigmas, 2, 1.0e-4);
    assert close(s2, sqrt(0.52));

    // n-var with covariance, diagonal-only Cov (= independent case) must
    // reproduce the same result as ep_propagate_independent above.
    let cov: Vec<f64> = vec(0.01, 0.0, 0.0, 0.04);
    let s3: f64 = ep_propagate_covariance(prod2, ref x, ref cov, 2, 1.0e-4);
    assert close(s3, sqrt(0.52));

    // N3.6 closed-form product shortcut on the SAME f=x1*x2 must agree
    // with the general finite-difference path (s2) -- this is the
    // "validate together" composed check.
    let s4: f64 = ep_product2(3.0, 0.1, 4.0, 0.2);
    assert close(s4, sqrt(0.52));
    assert close(s4, s2);

    // Quotient: f=a/b, same relative-error-in-quadrature form as product.
    let s5: f64 = ep_quotient2(3.0, 0.1, 4.0, 0.2);
    let rel: f64 = sqrt((0.1 / 3.0) * (0.1 / 3.0) + (0.2 / 4.0) * (0.2 / 4.0));
    assert close(s5, (3.0 / 4.0) * rel);

    // Sum shortcuts.
    let s6: f64 = ep_sum2(0.1, 0.2);
    assert close(s6, sqrt(0.05));

    let three: Vec<f64> = vec(0.1, 0.2, 0.2);
    let s7: f64 = ep_sum_n(ref three, 3);
    assert close(s7, 0.3);

    return 0;
}
