// Tests for N3.2: interval elementary functions (sqrt/exp/log/pow/sin/cos).
// Run with:  vanic test tests/test_elementary.vani

use "../src/lib.vani";

fn close(a: f64, b: f64) -> bool {
    return abs(a - b) < 1.0e-6;
}

fn main() -> i64 {
    // Monotonic functions: endpoints map straight across.
    let s: Interval = iv_sqrt(iv_new(4.0, 9.0));
    assert close(s.lo, 2.0);
    assert close(s.hi, 3.0);

    let ex: Interval = iv_exp(iv_new(0.0, 1.0));
    assert close(ex.lo, 1.0);
    assert close(ex.hi, exp(1.0));

    let lg: Interval = iv_log(iv_new(1.0, exp(1.0)));
    assert close(lg.lo, 0.0);
    assert close(lg.hi, 1.0);

    // Integer power, odd exponent: monotonic, straight endpoint mapping.
    let p3: Interval = iv_pow_i64(iv_new(2.0, 3.0), 3);
    assert close(p3.lo, 8.0);
    assert close(p3.hi, 27.0);

    // Integer power, even exponent, both endpoints positive.
    let p2a: Interval = iv_pow_i64(iv_new(2.0, 3.0), 2);
    assert close(p2a.lo, 4.0);
    assert close(p2a.hi, 9.0);

    // Integer power, even exponent, both endpoints negative: magnitude
    // increases as x moves away from 0, so [-3,-2]^2 = [4,9], not [9,4].
    let p2b: Interval = iv_pow_i64(iv_new(0.0 - 3.0, 0.0 - 2.0), 2);
    assert close(p2b.lo, 4.0);
    assert close(p2b.hi, 9.0);

    // Integer power, even exponent, spans zero: minimum is AT zero, not
    // at either endpoint. [-2,3]^2 -> [0,9].
    let p2c: Interval = iv_pow_i64(iv_new(0.0 - 2.0, 3.0), 2);
    assert close(p2c.lo, 0.0);
    assert close(p2c.hi, 9.0);

    // Negative integer power: [2,3]^-1 = 1/[2,3] = [1/3, 1/2].
    let pm1: Interval = iv_pow_i64(iv_new(2.0, 3.0), 0 - 1);
    assert close(pm1.lo, 1.0 / 3.0);
    assert close(pm1.hi, 0.5);

    // sin over a full period (width >= 2*pi) must be the whole [-1,1]
    // range, not just what the endpoints happen to show.
    let full: Interval = iv_sin(iv_new(0.0, 7.0));
    assert close(full.lo, 0.0 - 1.0);
    assert close(full.hi, 1.0);

    // sin over [pi, 2pi]: endpoints are both ~0, but the interval crosses
    // the trough at 3pi/2 where sin = -1 -- an endpoint-only evaluation
    // would wrongly report [~0, ~0].
    let pi: f64 = f64_pi();
    let trough: Interval = iv_sin(iv_new(pi, 2.0 * pi));
    assert close(trough.lo, 0.0 - 1.0);
    assert trough.hi < 1.0e-6;

    // cos over [-0.5, 0.5]: endpoints are both cos(0.5) ~= 0.8776, but the
    // interval crosses the peak at x=0 where cos = 1 -- this is exactly
    // the critical-point case the roadmap called "the fiddly part".
    let peak: Interval = iv_cos(iv_new(0.0 - 0.5, 0.5));
    assert close(peak.hi, 1.0);
    assert close(peak.lo, cos(0.5));

    return 0;
}
