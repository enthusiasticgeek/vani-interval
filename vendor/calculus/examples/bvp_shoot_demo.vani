// Boundary-value problem demo: y'' = -y on [0, pi/2] with y(0) = 0,
// y(pi/2) = 1 -- the exact solution is y(t) = sin(t). Solved via the
// shooting method starting from two deliberately wrong initial-slope
// guesses; bvp_shoot_solve's secant search finds the correct slope
// (y'(0) = 1) on its own.
//
// Run with:  vanic run examples/bvp_shoot_demo.vani

use "../src/lib.vani";

fn shm(t: f64, y: f64, v: f64) -> f64 { return 0.0 - y; }

fn main() -> i64 {
    let pi: f64 = f64_pi();
    let n_steps: i64 = 20;
    let traj: Vec<f64> = bvp_shoot_solve(0.0, pi / 2.0, 0.0, 1.0, shm, 0.5, 1.5, n_steps, 1.0e-10, 30);

    let h: f64 = (pi / 2.0) / (n_steps as f64);
    print "t          y(t)           sin(t)         error";
    let i: i64 = 0;
    while i <= n_steps {
        let t: f64 = (i as f64) * h;
        let exact: f64 = sin(t);
        print t, traj[i], exact, abs(traj[i] - exact);
        i = i + 1;
    }

    return 0;
}
