use "../src/lib.vani";

// kahan_sum: [1,2,3,4,5] = 15.
#[test]
fn test_kahan_sum_integers() -> i64 {
    let xs: Vec<f64> = vec(1.0);
    push(mut ref xs, 2.0);
    push(mut ref xs, 3.0);
    push(mut ref xs, 4.0);
    push(mut ref xs, 5.0);
    let result: f64 = kahan_sum(xs);
    assert abs(result - 15.0) < 1.0e-12;
    return 0;
}

// kahan_sum on 0.1+0.2+0.3 = 0.6 (Kahan avoids rounding drift).
#[test]
fn test_kahan_sum_decimals() -> i64 {
    let xs: Vec<f64> = vec(0.1);
    push(mut ref xs, 0.2);
    push(mut ref xs, 0.3);
    let result: f64 = kahan_sum(xs);
    assert abs(result - 0.6) < 1.0e-12;
    return 0;
}

// partial_sum: [1,2,3] → [1,3,6].
#[test]
fn test_partial_sum() -> i64 {
    let xs: Vec<f64> = vec(1.0);
    push(mut ref xs, 2.0);
    push(mut ref xs, 3.0);
    let ps: Vec<f64> = partial_sum(xs);
    assert abs(ps[0] - 1.0) < 1.0e-12;
    assert abs(ps[1] - 3.0) < 1.0e-12;
    assert abs(ps[2] - 6.0) < 1.0e-12;
    return 0;
}

// running_mean_update: online mean of [5, 3] = 4.
#[test]
fn test_running_mean_two_samples() -> i64 {
    let m1: f64 = running_mean_update(0.0, 5.0, 1);
    let m2: f64 = running_mean_update(m1, 3.0, 2);
    assert abs(m1 - 5.0) < 1.0e-12;
    assert abs(m2 - 4.0) < 1.0e-12;
    return 0;
}

// running_mean_update: online mean of [10, 20, 30] = 20.
#[test]
fn test_running_mean_three_samples() -> i64 {
    let m: f64 = running_mean_update(0.0, 10.0, 1);
    let m2: f64 = running_mean_update(m, 20.0, 2);
    let m3: f64 = running_mean_update(m2, 30.0, 3);
    assert abs(m3 - 20.0) < 1.0e-12;
    return 0;
}

fn main() -> i64 { return 0; }
